<routes>
    <vType id="ambulance" vClass="emergency" color="255,0,0" guiShape="emergency" maxSpeed="30.0" accel="3.0" decel="4.5" length="6.5"/>
    <vType id="pedestrian" vClass="pedestrian" color="255,192,203" guiShape="pedestrian" maxSpeed="1.5"/>

    <vTypeDistribution id="mixed_traffic">
        <vType id="car" probability="0.7" vClass="passenger" guiShape="passenger" color="1,0,0"/>
        <vType id="bus" probability="0.2" vClass="bus" guiShape="bus" color="0,0,1"/>
        <vType id="truck" probability="0.1" vClass="truck" guiShape="truck" color="0,1,0"/>
    </vTypeDistribution>

    <route id="WE" edges="E3 E0.54 E0"/>
    <route id="EW" edges="-E01 -E0 -E00"/>

    <route id="NS" edges="E1 E1.39"/>
    <route id="SN" edges="-E1 -E10"/>
    
    <route id="N_to_E" edges="E1 E0.54 E0"/>
    <route id="S_to_E" edges="-E1 E0.54 E0"/>
    <route id="W_to_N" edges="-E01 -E0 E1.39"/>
    <route id="W_to_S" edges="-E01 -E0 -E10"/>
    <route id="N_to_W" edges="E1 -E00"/>
    <route id="E_to_S" edges="E3 -E10"/>
    <route id="E_to_N" edges="E3 E1.39"/>
    <route id="S_to_W" edges="-E1 -E00"/>

    <route id="NS_J1" edges="-E2 E4"/>
    <route id="SN_J1" edges="-E4 E2"/>
    
    <route id="N_to_E_J1" edges="-E2 E0"/>
    <route id="N_to_W_J1" edges="-E2 -E0 -E00"/>
    <route id="S_to_E_J1" edges="-E4 E0"/>
    <route id="S_to_W_J1" edges="-E4 -E0 -E00"/>
    <route id="E_to_N_J1" edges="-E01 E2"/>
    <route id="E_to_S_J1" edges="-E01 E4"/>
    <route id="W_to_N_J1" edges="E3 E0.54 E2"/>
    <route id="W_to_S_J1" edges="E3 E0.54 E4"/>

    <flow id="f_WE" route="WE" type="mixed_traffic" begin="0" end="3600" probability="0.04"/>
    <flow id="f_EW" route="EW" type="mixed_traffic" begin="0" end="3600" probability="0.04"/>
    
    <flow id="f_NS" route="NS" type="mixed_traffic" begin="0" end="3600" probability="0.05"/>
    <flow id="f_SN" route="SN" type="mixed_traffic" begin="0" end="3600" probability="0.05"/>
    <flow id="f_N_to_E" route="N_to_E" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>
    <flow id="f_N_to_W" route="N_to_W" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>
    <flow id="f_S_to_E" route="S_to_E" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>
    <flow id="f_S_to_W" route="S_to_W" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>

    <flow id="f_NS_J1" route="NS_J1" type="mixed_traffic" begin="0" end="3600" probability="0.05"/>
    <flow id="f_SN_J1" route="SN_J1" type="mixed_traffic" begin="0" end="3600" probability="0.05"/>
    <flow id="f_N_to_E_J1" route="N_to_E_J1" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>
    <flow id="f_N_to_W_J1" route="N_to_W_J1" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>
    <flow id="f_S_to_E_J1" route="S_to_E_J1" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>
    <flow id="f_S_to_W_J1" route="S_to_W_J1" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>
    <flow id="f_E_to_N_J1" route="E_to_N_J1" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>
    <flow id="f_E_to_S_J1" route="E_to_S_J1" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>
    <flow id="f_W_to_N_J1" route="W_to_N_J1" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>
    <flow id="f_W_to_S_J1" route="W_to_S_J1" type="mixed_traffic" begin="0" end="3600" probability="0.02"/>

    <flow id="f_emerg_NS" route="NS" type="ambulance" begin="0" end="3600" probability="0.001"/>
    <flow id="f_emerg_SN" route="SN" type="ambulance" begin="0" end="3600" probability="0.001"/>
    <flow id="f_emerg_WE" route="WE" type="ambulance" begin="0" end="3600" probability="0.001"/>
    <flow id="f_emerg_EW" route="EW" type="ambulance" begin="0" end="3600" probability="0.001"/>

    <personFlow id="ped_walk_SN" begin="0" end="3600" probability="0.01">
        <walk from="-E1" to="-E10"/> 
    </personFlow>
    <personFlow id="ped_walk_EW" begin="0" end="3600" probability="0.01">
        <walk from="-E00" to="-E0"/> 
    </personFlow>
    <personFlow id="ped_walk_SN_J1" begin="0" end="3600" probability="0.01">
        <walk from="-E4" to="-E2"/> 
    </personFlow>
    <personFlow id="ped_walk_EW_J1" begin="0" end="3600" probability="0.01">
        <walk from="-E01" to="-E0"/> 
    </personFlow>

</routes>